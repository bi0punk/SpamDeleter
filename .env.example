# --- Proveedor ---
# gmail | outlook | yahoo | custom
PROVIDER=gmail

# IMAP custom (si PROVIDER=custom)
# IMAP_SERVER=imap.example.com
# IMAP_PORT=993

# --- Carpeta SPAM ---
# Gmail:   "[Gmail]/Spam"
# Outlook:  Junk
# Yahoo:    Bulk Mail
# SPAM_FOLDER="[Gmail]/Spam"

# --- Autenticacion basica ---
EMAIL=tu@email.com
PASSWORD=tu_contraseña_o_app_password

# --- OAuth2 (opcional - reemplaza PASSWORD si se configura) ---
# OAUTH2_ENABLED=true
# OAUTH2_PROVIDER=google       # google | microsoft
# OAUTH2_CLIENT_ID=xxx
# OAUTH2_CLIENT_SECRET=xxx
# OAUTH2_REFRESH_TOKEN=xxx

# --- Intervalo por defecto (opcional) ---
# INTERVAL=1h
